*.log
*.tar.gz
*.db
*.bak
*.tmp

# Backups produced by backup.sh
netch-backup-*.tar.gz

# Certs / secrets (should never live in the repo)
*.pem
*.key
.env

# Clash provider/rule caches
providers/
rules/

# OS cruft
.DS_Store
Thumbs.db

# Scratch / API inspection temp files
_*.json
